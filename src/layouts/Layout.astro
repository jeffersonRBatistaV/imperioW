---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const base = import.meta.env.BASE_URL;
const { title = "Imperio W — Arena, Grava y Materiales", description = "Distribución de arena azul, itabo, grava y empaque. Entregas con camiones 17-20mt a todo el país desde San Cristóbal." } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href={`${base}images/logo.png`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="antialiased">
    <div class="grain-overlay" />
    <slot />
  </body>
</html>
