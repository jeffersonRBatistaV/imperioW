---
const whatsapp = "https://wa.me/18492507070?text=Hola%2C%20quiero%20cotizar%20una%20entrega";

interface Material {
  name: string;
  desc: string;
  img: string;
  badge?: string;
}

const materials: Material[] = [
  {
    name: "Arena Azul",
    desc: "Arena fina de alta calidad para construcción, filtración y acabados.",
    img: "/images/arenapaete.jpeg",
    badge: "Más vendido",
  },
  {
    name: "Itabo",
    desc: "Agregado grueso ideal para mezclas de concreto, rellenos y bases.",
    img: "/images/itabo.webp",
  },
  {
    name: "Grava",
    desc: "Piedra triturada en varios calibres para construcción, drenaje y decoración.",
    img: "/images/grava.avif",
  },
  {
    name: "Empaque",
    desc: "Material de relleno compactable para nivelación de terrenos y sub-bases.",
    img: "/images/empaque.jpg",
  },
];
---

<section id="materiales" class="relative py-28 lg:py-40 overflow-hidden">
  <div class="absolute inset-0 bg-surface dark:bg-surface-dark" />
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="text-center mb-16 lg:mb-20">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tighter text-ink dark:text-ink-dark">
        Nuestros <span class="text-brand">Materiales</span>
      </h2>
      <p class="mt-4 text-lg text-muted leading-relaxed max-w-[50ch] mx-auto">
        Contamos con los mejores materiales para tu proyecto de construcción.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        materials.map((mat) => (
          <div class="group relative p-1.5 rounded-[2rem] bg-border dark:bg-border-dark transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:-translate-y-1">
            <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden bg-white dark:bg-surface-dark">
              <div class="relative h-48 overflow-hidden bg-stone-200 dark:bg-stone-800">
                <img
                  src={mat.img}
                  alt={mat.name}
                  class="w-full h-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent" />
                {mat.badge && (
                  <span class="absolute top-3 left-3 z-10 px-3 py-1 rounded-full bg-brand text-white text-[10px] font-bold uppercase tracking-[0.1em] shadow-lg">
                    {mat.badge}
                  </span>
                )}
              </div>
              <div class="p-6 space-y-3">
                <h3 class="text-xl font-bold text-ink dark:text-ink-dark">{mat.name}</h3>
                <p class="text-sm text-muted leading-relaxed">{mat.desc}</p>
                <a
                  href={whatsapp}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-semibold text-brand hover:text-brand-light transition-colors"
                >
                  Cotizar {mat.name.toLowerCase()}
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" /></svg>
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
