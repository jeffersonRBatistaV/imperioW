---
const base = import.meta.env.BASE_URL;
const whatsapp = "https://wa.me/18492507070?text=Hola%2C%20quiero%20cotizar%20una%20entrega";
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-surface-dark/80 backdrop-blur-xl border-b border-border/50 dark:border-border-dark/50">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <a href="/" class="flex items-center gap-2.5">
        <img src={`${base}images/logo.png`} alt="Imperio W" class="w-9 h-9 object-contain" />
        <span class="font-bold text-lg text-ink dark:text-ink-dark hidden sm:inline">Imperio W</span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#materiales" class="text-sm font-medium text-muted dark:text-muted-dark hover:text-brand dark:hover:text-brand transition-colors">Materiales</a>
        <a href="#flota" class="text-sm font-medium text-muted dark:text-muted-dark hover:text-brand dark:hover:text-brand transition-colors">Flota</a>
        <a href="#cobertura" class="text-sm font-medium text-muted dark:text-muted-dark hover:text-brand dark:hover:text-brand transition-colors">Cobertura</a>
        <a href="#clientes" class="text-sm font-medium text-muted dark:text-muted-dark hover:text-brand dark:hover:text-brand transition-colors">Clientes</a>
        <a
          href={whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-brand text-white text-sm font-semibold transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:bg-brand-dark active:scale-[0.97] min-h-[44px] min-w-[44px]"
