---
const whatsapp = "https://wa.me/18492507070?text=Hola%2C%20quiero%20cotizar%20una%20entrega";
---

<section class="relative min-h-[100dvh] flex items-center overflow-hidden py-28 lg:py-40">
  <video class="absolute inset-0 w-full h-full object-cover" autoplay muted loop playsinline preload="auto">
    <source src="https://videos.pexels.com/video-files/12236116/12236116-hd_1920_1080_30fps.mp4" type="video/mp4" />
  </video>
  <div class="absolute inset-0 bg-black/55" />
  <div class="absolute inset-0 bg-gradient-to-r from-black/30 to-transparent" />
  <div class="relative z-10 w-full max-w-[1400px] mx-auto px-6 lg:px-12 pt-24 lg:pt-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/15 text-white text-[11px] font-semibold uppercase tracking-[0.2em]">
          <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse" />
          Entregas a todo el país
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-black tracking-tighter leading-none text-balance text-white">
          <span class="text-brand">Imperio</span> W
        </h1>
        <p class="text-lg sm:text-xl text-white/80 leading-relaxed max-w-[50ch]">
          Arena azul, itabo, grava y empaque. Entregas con camiones de 17, 18 y 20 mt³ a toda la República Dominicana.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={whatsapp}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative inline-flex items-center gap-3 px-10 py-5 rounded-full bg-brand text-white text-lg font-bold overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:bg-brand-dark active:scale-[0.97] min-h-[44px]"
          >
            <span class="relative z-10">Cotizar entrega</span>
            <span class="relative z-10 w-8 h-8 rounded-full bg-white/20 flex items-center justify-center transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
              <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75" />
              </svg>
            </span>
          </a>
          <a
            href="#materiales"
            class="inline-flex items-center gap-2 px-8 py-4 rounded-full border-2 border-white/50 text-white text-base font-semibold transition-all duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] hover:border-brand hover:text-brand active:scale-[0.97] min-h-[44px]"
          >
            Ver materiales
          </a>
        </div>
        <div class="flex flex-wrap items-center gap-4 pt-2">
          <a href="tel:+18292597070" class="inline-flex items-center gap-2 text-sm text-white/60 hover:text-brand transition-colors">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/></svg>
            +1 (829) 259-7070
          </a>
        </div>
      </div>
      <div class="relative hidden lg:block">
        <div class="relative p-2 rounded-[2rem] bg-gradient-to-b from-brand/30 to-transparent">
          <div class="rounded-[calc(2rem-0.375rem)] overflow-hidden bg-white/90 dark:bg-surface-dark/90 backdrop-blur-xl">
            <div class="p-8 lg:p-12 space-y-6">
              <div class="flex items-center gap-3 text-ink dark:text-ink-dark">
                <div class="w-12 h-12 rounded-xl bg-brand flex items-center justify-center text-white font-black text-xl">IW</div>
                <div>
                  <div class="font-semibold text-sm">Imperio W</div>
                  <div class="text-xs text-muted dark:text-muted-dark">Materiales desde 2010</div>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div class="p-4 rounded-xl bg-amber-50/80 dark:bg-amber-950/30 border border-border dark:border-border-dark">
                  <div class="text-2xl font-black text-brand">17-20</div>
                  <div class="text-xs text-muted dark:text-muted-dark">mt³ por viaje</div>
                </div>
                <div class="p-4 rounded-xl bg-blue-50/80 dark:bg-blue-950/30 border border-border dark:border-border-dark">
                  <div class="text-2xl font-black text-brand">4+</div>
                  <div class="text-xs text-muted dark:text-muted-dark">tipos de material</div>
                </div>
                <div class="p-4 rounded-xl bg-green-50/80 dark:bg-green-950/30 border border-border dark:border-border-dark">
                  <div class="text-2xl font-black text-brand">RD</div>
                  <div class="text-xs text-muted dark:text-muted-dark">Cobertura nacional</div>
                </div>
                <div class="p-4 rounded-xl bg-red-50/80 dark:bg-red-950/30 border border-border dark:border-border-dark">
                  <div class="text-2xl font-black text-brand">10+</div>
                  <div class="text-xs text-muted dark:text-muted-dark">años de experiencia</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
